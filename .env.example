# .env.example — copy to .env and fill in values
#
#   cp .env.example .env
#
# Variables with PUBLIC_ prefix are available in the browser.
# Variables without it are server-only (frontmatter, API routes).

# Google Analytics (optional — omit to disable tracking)
PUBLIC_GTAG_ID=

# HubSpot forms (optional — omit to use component defaults)
# PUBLIC_HUBSPOT_PORTAL_ID=
# PUBLIC_HUBSPOT_FORM_ID=
