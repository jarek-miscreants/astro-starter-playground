---
  // CardFeatured.astro
  interface Props {
    eyebrow?: string;
    title?: string;
    description?: string;
    border?: "all" | "y" | "x" | "none";
    class?: string;
    titleClass?: string;
    titleTag?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  }
  const {
    eyebrow,
    title,
    description,
    border = "all",
    class: className = "",
    titleClass = "h3",
    titleTag: TitleTag = "h3",
  } = Astro.props;

  const borderClass = {
    all:  "border border-grid-border",
    y:    "border-y border-grid-border",
    x:    "border-x border-grid-border",
    none: "",
  }[border];

  const hasMedia = Astro.slots.has("media");
---
  <div class:list={["px-4 pt-4 md:pt-8 md:px-8 rounded-sm relative", hasMedia ? "pb-0" : "pb-8", borderClass, className]}>
    <div class="flex flex-col gap-4">
      {eyebrow && <p class="text-eyebrow text-muted">{eyebrow}</p>}
      {title && <TitleTag class={titleClass}>{title}</TitleTag>}
      {description && <p class="text-muted">{description}</p>}
      <slot />   {/* default slot — renders any children passed between <CardFeatured>…</CardFeatured> */}
      <slot name="media" />   {/* renders nothing if caller passes nothing */}
      <slot name="button" />
    </div>
  </div>


